        Input.value = variant.id;
        history.replaceState(null, '', `?variant=${variant.id}`);
        Price.textContent = format.format(variant.price / 100);

        if (variant.compare_at_price > variant.price) {
          compareAtPrice.textContent = format.format(variant.compare_at_price / 100);
          compareAtPrice.style.display = 'inline';
        } else {
          compareAtPrice.style.display = 'none';
        }

        if (variant.available) {
          CartBtn.disabled = false;
          CartBtn.textContent = 'Add to cart';
          SoldOutText.style.display = 'none';
        } else {
          CartBtn.disabled = true;
          CartBtn.textContent = 'Sold Out';
        }

        const imageId = variant.image_id;

        $('.top-slider').hide();
        $('.bottom-slider').hide();

        const slick = () => {
          if ($('.top-slider').hasClass('slick-initialized')) {
            updateSlider(variant.option1, imageId);
          } else {
            requestAnimationFrame(slick);
          }
        };

        slick();
        {% comment %} console.log(slick); {% endcomment %}
      } else {
        Input.value = '';
        CartBtn.disabled = true;
        CartBtn.textContent = 'Unavailable';
        compareAtPrice.style.display = 'none';
      }
    };
    console.log(updateVariant);

    // Manual changes.....
    document.querySelectorAll('.select-option input[type="radio"]').forEach((r) => {
      r.addEventListener('change', () => {
        const selecte = [...document.querySelectorAll('.select-option input[type="radio"]:checked')].map((r) =>
          r.value.trim()
        );
        console.log(selecte);
        const variant = variants.find((v) => selecte.every((val, index) => v[`option${index + 1}`] === val));
        console.log(variant);
        updateVariant(variant);
      });
    });

    // page loading on url.....
    const url = new URLSearchParams(window.location.search);
    console.log(url);
    const variantid = url.get('variant');
    console.log(variantid);

    let samevariant = null;
    console.log(samevariant);
    if (variantid) {
      samevariant = variants.find((v) => v.id == variantid);
    }

    if (samevariant) {
      updateVariant(samevariant);

      const imageid = samevariant.image_id;
      console.log(imageid);
      const slides = document.querySelectorAll('.top-slider-inner');
      console.log(slides);

      let matchedIndex = -1;
      slides.forEach((slide, index) => {
        if (slide.dataset.id == imageid) {
          matchedIndex = index;
        }
      });

      if (matchedIndex !== -1) {
        $('.top-slider').slick('slickGoTo', matchedIndex);
        $('.bottom-slider').slick('slickGoTo', matchedIndex);
      }
    }
  });
{% endcomment %}

