
<section class="product-details" data-section="main-product" id="product">
  <div class="product-details-inner">
    <div class="container-fluid">
      <div class="row">
        <div class="col-7 col-m-12">
          <div class="product-detail-img">
            {% if product.images.size > 0 %}
              <div class="top-slider slick-slider pswp-gallery">
                {% for image in product.images %}
                  <div class="top-slider-inner" data-id="{{ image.id }}">
                    <div class="slide-img zoom-container" data-action="open-lightbox-trigger">
                      {% comment %}
                          <img
                          width=""
                          height=""
                          class="product-zoom-img"
                          src="{{ image | image_url: width: 800 }}"
                          data-full-src="{{ image | image_url: width: 2000 }}"
                          alt="{{ image.alt | escape }}"
                          {% if section.settings.enable_hover_zoom %}
                            data-zoomable="true"
                          {% endif %}
                        >
                      {% endcomment %}
                    </div>

                    <div class="slide-img" id="product-gallery">
                      {% comment %}
                        <img
                          width=""
                          height=""
                          class="image-zoom"
                          src="{{ image | image_url: width: 800 }}"
                          data-zoom="{{ image | image_url: '1080x1080', scale: 2 }}"
                          alt="{{ image.alt | escape }}"
                        >
                      {% endcomment %}
                      {% comment %}
                        <a
                          href="{{ image | image_url: width:1400 }}"
                          data-featherlight="image"
                          data-gallery="product-gallery"
                        >
                          <img src="{{ image | image_url: width: 800 }}" alt="{{ image.alt }}">
                        </a>
                      {% endcomment %}

                      {% comment %}
                        <span class="zoom-container">
                          <img src="{{ image | image_url: width: 800 }}" data-zoom-image="large-image.jpg" alt="Product Image">
                        </span>
                      {% endcomment %}
                      {% comment %}
                        <img
                              id="MainZoomImage"
                            src="{{ image | image_url: width: 800 }}"
                          data-zoom-src="{{ image | image_url: '2048x2048' }}"
                        alt="{{ image.alt | escape }}">
                      {% endcomment %}

                      {% comment %} // final result for zoomin {% endcomment %}

                      <a
                        data-fancybox="gallery"
                        href="{{ image |image_url: width:800 }}"
                      >
                        <img
                          id="MainZoomImage"
                          src="{{ image | image_url: width:800 }}"
                          alt="{{ product.title }}"
                        >
                      </a>

                      {% comment %}
                        <a
                          href="{{ image | image_url: width:800 }}"
                          data-pswp-width="2048"
                          data-pswp-height="2048"
                          target="_blank"
                        >
                          <img
                            src="{{ image | image_url: width:800 }}"
                            alt="{{ image.alt | escape }}"
                          >
                        </a>
                      {% endcomment %}
                    </div>

                    {% comment %}
                      <a
                        href="{{ product.featured_image | product_img_url: 'original' }}"
                        class="MagicZoom"
                        id="zoom"
                        title="{{ product.title | escape }}"
                      >
                        {{ product.featured_image | product_img_url: 'master' | img_tag }}
                      </a>
                    {% endcomment %}
                  </div>
                {% endfor %}
              </div>
              {% comment %}
                <div id="product-lightbox-modal" class="lightbox-modal">
                  <div class="lightbox-content">
                    <!-- Ensure the close button class matches your JS selector -->
                    <span class="close-button">&times;</span>
                    <img id="lightbox-image" alt="Full size product view">
                  </div>
                </div>
              {% endcomment %}
              <div class="bottom-slider slick-slider">
                {% for image in product.images %}
                  <div class="bottom-slider-inner" data-id="{{ image.id }}">
                    <div class="slide-img">
                      <img width="" height="" src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}">
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>

        <div class="col-5 col-m-12">
          <div class="product-info-content">
            {% for block in section.blocks %}
              {% case block.type %}
                {%- when '@app' -%}
                  {% render block %}

                {% when 'product_title' %}
                  {% if product.title != blank %}
                    <h1 class="h3">{{ product.title }}</h1>
                  {% endif %}
                  {% comment %} //meta Object {% endcomment %}
                  {% comment %}
                    {{ product.metafields.custom.heding_title.value }}==============
                    {{ product.metafields.custom.customerlove.value }}
                    {{ product.metafields.custom.accordian.value }}
                    {{ product.metafields.custom.demo1.value }}
                  {% endcomment %}

                  {% comment %} //metafields {% endcomment %}
                  {% comment %} {{ page.metafields.custom.pages1 }}          {% endcomment %}
                  {% comment %}
                    {{ product.metafields.custom.test.value -}}
                    <br>
                    {{ product.metafields.custom.product.value -}}
                    <br>
                    Date:{{ product.metafields.custom.product2.value }}
                    <br>
                    Dimansions :{{ product.metafields.custom.product3.value }}
                    <p>{{ product.metafields.namespace.key_name }}</p>

                    <br>
                    files:
                    {%- if product.metafields.custom.product5 != blank %}
                      {% assign product_image = product.metafields.custom.product5.value %}
                      <img
                        src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/titanwatch.webp?v=1756890025"
                        alt="product_image"
                        height="150px"
                      >
                    {% endif %}

                    {% if product.metafields.custom.product4 != blank %}
                      {% assign featured_product = product.metafields.custom.product4.value %}
                      <div>
                        <h3>Featured Product:</h3>
                        <a href="{{ featured_product.url }}">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/w2_f5b42b36-4467-4a3c-8807-65ed9d666799.jpg?v=1757064549"
                            alt="{{ featured_product.title }}"
                            height="100px"
                          >
                          <h4>{{ featured_product.title }}</h4>
                        </a>
                      </div>
                    {% endif %}
                    {% comment %} Assign the metafield value to a variable for easier use {% endcomment %}
                    {% assign bundle_items = product.metafields.custom.bundle_products.value %}

                    {% comment %} Check if the metafield list is not empty {% endcomment %}
                    {% if bundle_items != blank %}
                      <h3>Bundle Includes:</h3>
                      <ul>
                        {% for item in bundle_items %}
                          <li>{{ item.title }}</li>
                        {% endfor %}
                      </ul>
                    {% endif %}

                    {% assign bundle_products = product.metafields.custom.bundle_product.value %}

                    {% if bundle_products != blank %}
                      <h2>Bundle product</h2>
                      <ul>
                        {% for bundle_product in bundle_products %}
                          <li>
                            <a href="{{ bundle_product.url }}">{{ bundle_product.title }}</a>
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}

                    <br>
                    variants :{{ product.metafields.custom.product6.value }}
                    <br>
                    money :{{ product.metafields.custom.product7.value }}
                    <br>
                    {{ product.metafields.custome.metafield.value }}
                    <br>
                    variant :{{ product.variant.metafields.custom.variant1.value }}
                    <br>
                    {% if product.metafields.custom_fields.color_metafield != blank %}
                      <div class="custom-field custom-field__color-metafield custom-field__type--color">
                        <h3 class="custom-field--title">Color metafield</h3>
                        <div class="custom-field--value">
                          {{ product.metafields.custom_fields.color_metafield | metafield_tag }}
                        </div>
                      </div>
                    {% endif %}

                    {% if product.metafields.custom.dimensions != blank %}
                      <div class="custom-field custom-field__dimensions custom-field__type--single-line-text-field">
                        <h3 class="custom-field--title">Dimensions</h3>
                        <div class="custom-field--value">
                          {{ product.metafields.custom.dimensions | metafield_tag }}
                        </div>
                      </div>
                    {% endif %}
                  {% endcomment %}

                  {% comment %}
                    {% when 'price' %}
                    <p class="product-price" id="ProductPrice">
                      <span id="Price" class="h4">
                        {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}
                      </span>
                      {% if product.selected_or_first_available_variant.compare_at_price
                          > product.selected_or_first_available_variant.price
                      %}
                        <del id="CompareAtPrice">
                          {{
                            product.selected_or_first_available_variant.compare_at_price
                            | money_without_trailing_zeros
                          }}
                        </del>
                      {% endif %}
                    </p>
                  {% endcomment %}

                {% when 'price' %}
                  <p class="product-price">
                    <span id="Price" class="h4">
                      {{ product.selected_or_first_available_variant.price | money }}
                    </span>

                    <span
                      id="CompareAtPrice"
                      style="text-decoration: line-through; color: gray; {% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}display:none;{% endunless %}"
                    >
                      {{ product.selected_or_first_available_variant.compare_at_price | money }}
                    </span>
                  </p>
                  {{ product.metafields.number.value }}
                {% when 'color_swatch' %}
                  {% comment %} {% unless product.has_only_default_variant %} {% endcomment %}
                  {% for option in product.options_with_values %}
                    <div class="select-option">
                      <h5>STEP {{ forloop.index }}, SELECT A {{ option.name }}</h5>
                      <div class="shop-by-color {% unless option.name == 'Color' %}size-option{% endunless %}">
                        <ul>
                          {% for value in option.values %}
