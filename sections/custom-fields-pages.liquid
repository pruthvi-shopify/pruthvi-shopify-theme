{% render "blocks.custom_fields" with resource_type: "pages", blocks: section.blocks %}
{% schema %}
  {
    "name": {
        "en": "Custom Fields"
    },
    "settings": [
        {
            "type": "paragraph",
            "content": "[View Documentation](https:\/\/custom-fields.docs.bonify.io\/)"
        },
        {
            "type": "paragraph",
            "content": "[Edit Custom Fields](https:\/\/customfields.bonify.io\/dashboard\/pruthvi-cirkle.myshopify.com\/pages\/configure)"
        }
    ],
    "templates": [
        "page"
    ],
    "presets": [
        {
            "name": "Custom Fields",
            "blocks": []
        }
    ],
    "blocks": [
        {
            "type": "cf_f_dtf",
            "name": {
                "en": "Date and Time"
            },
            "settings": [
                {
                    "type": "select",
                    "id": "key",
                    "label": "Select a Field",
                    "options": [
                        {
                            "value": "custom.pages1",
                            "label": "pages1"
                        }
                    ]
                }
            ]
        },
        {
            "type": "cf_f_ratef",
            "name": {
                "en": "Rating"
            },
            "settings": [
                {
                    "type": "select",
                    "id": "key",
                    "label": "Select a Field",
                    "options": [
                        {
                            "value": "custom_fields.rating",
                            "label": "Rating"
                        }
                    ]
                }
            ]
        }
    ]
}
{% endschema %}
