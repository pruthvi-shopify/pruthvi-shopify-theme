<section class="collection-prod you-may-like" data-section="recently-viewed">
  <div class="collection-prod-inner">
    <div class="container-fluid">
      <h3 class="text-center">recent view</h3>
      <div class="row" id="recently-viewed-section-products">
        {% comment %}
          <div class="col-4 col-s-6">
            <div class="product-card">
              <div class="prod-card-img text-center">
                <div class="prod-card-badge">
                  <div>
                    <form method="post" action="/cart/add">
                      <input type="hidden" name="form_type" value="product">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="product-form__submit">
                        <img
                          src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/cart-icon.png?v=1751865122"
                          alt="Add to Cart Icon"
                        >
                      </button>
                    </form>
                  </div>
                  <div>
                    <a href="{{ product.url }}" class="quick-view">
                      <img
                        src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/zoom.png?v=1751865146"
                        alt="zoom"
                      >
                    </a>
                  </div>
                </div>
                <div class="prod-img">
                  {% if product.featured_image %}
                    <a href="{{ product.url }}">
                      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
                    </a>
                  {% endif %}
                </div>

                {% if product.variants.size > 1 %}
                  <div class="prod-color mb-1">
                    <ul>
                      {% assign colors = product.variants | map: 'option1' | uniq %}
                      {% for color in colors %}
                        <li>
                          <a
                            href="#"
                            class="card-color-swatch"
                            style="background-color: {{ color | downcase }};"
                            title="{{ color }}"
                          ></a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>

                  <div class="prod-size-on-hover" style="margin-top: 8px;">
                    <ul style="display: flex; flex-wrap: wrap; gap: 6px; padding: 0; margin: 0; list-style: none;">
                      {% assign unique_sizes = product.variants | map: 'option2' | uniq %}
                      {% for size in unique_sizes %}
                        <li>
                          <span
                            class="card-size-swatch"
                            title="{{ size }}"
                            style="display: inline-block; padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 10px; background: #f8f8f8; color: #333;"
                            onmouseover="this.style.backgroundColor='#222'; this.style.color='#fff'; this.style.borderColor='#222';"
                            onmouseout="this.style.backgroundColor='#f8f8f8'; this.style.color='#333'; this.style.borderColor='#ccc';"
                          >
                            {{ size }}
                          </span>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

              <div class="prod-detail">
                <div class="prod-title">
                  <h4><a href="{{ product.url }}">{{ product.title }}</a></h4>
                </div>
                <div class="compare-price">
                  {% if product.compare_at_price > product.price %}
                    <span><del>{{ product.compare_at_price | money }}</del></span>
                  {% endif %}
                  <span>{{ product.price | money_without_trailing_zeros }}</span>
                </div>
              </div>
            </div>
          </div>
        {% endcomment %}
      </div>
    </div>
  </div>
</section>

 {% comment %} <script>
document.addEventListener("DOMContentLoaded", () => {
  const currentHandle = "{{ product.handle }}";
  const localStorageKey = "recently_viewed_handles";

  let handles = JSON.parse(localStorage.getItem(localStorageKey)) || [];
  
  // Step 3 & 4: Filter out the current product and add it to the start of the list
  handles = handles.filter(h => h !== currentHandle); // Remove current handle if it already exists
  handles.unshift(currentHandle); // Add current handle to the beginning
  handles = handles.slice(0, 4); // Keep only the last 4 unique handles

  // Store the updated array back into localStorage
  localStorage.setItem(localStorageKey, JSON.stringify(handles));

  // The products to display in the "recent view" section are those *not* the current product
  const recentHandles = handles.filter(h => h !== currentHandle);
  console.log(recentHandles);
  const container = document.getElementById("recently-viewed-section-products");

  if (!container || recentHandles.length === 0) {
    document.querySelector('.you-may-like').style.display = 'none';
    return;
  }
  
  // Step 5: Fetch API through array data, loop through and call HTML
  recentHandles.forEach(handle => {
    fetch(`/products/${handle}.js`)
      .then(res => {
        if (!res.ok) {
            throw new Error(`Could not fetch product ${handle}`);
        }
        return res.json();
      })
      .then(p => {
        const price = (p.price / 100).toFixed(2);
        const compareAtPrice = p.compare_at_price ? (p.compare_at_price / 100).toFixed(2) : null;
        {% comment %} console.log(compareAtPrice); {% endcomment %}
        
        const html = `
          <div class="col-4 col-s-6">
            <div class="product-card">
              <div class="prod-card-img text-center">
                <div class="prod-card-badge">
                  <div>
                    <form method="post" action="/cart/add">
                      <input type="hidden" name="form_type" value="product">
                      <!-- Use the first variant ID from the fetched product data -->
                      <input type="hidden" name="id" value="${p.variants[0].id}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="product-form__submit">
                        <img src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/cart-icon.png?v=1751865122">
                      </button>
                    </form>
                  </div>
                  <div>
                    <!-- Link Quick View to the fetched product handle -->
                     <a href="#" class="quick-view" data-product-handle="${handle}">
                        <img src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/zoom.png?v=1751865146" alt="zoom">
                      </a>
                  </div>
                </div>
                <div class="prod-img">
                  <a href="${p.url}">
                    <!-- Use Shopify's image resizing for consistency -->
                    <img src="${p.featured_image.replace('.png', '_600x.png').replace('.jpg', '_600x.jpg')}" alt="${p.title}">
                  </a>
                </div>
              </div>
              <div class="prod-detail">
                <div class="prod-title"><h4><a href="${p.url}">${p.title}</a></h4></div>
                <div class="compare-price">
                  ${compareAtPrice && compareAtPrice !== price
                    ? `<span><del>${compareAtPrice}</del></span>` : ''}
                  <span>${price}</span>
                </div>
              </div>
            </div>
          </div>
        `;
        container.insertAdjacentHTML("beforeend", html);
      })
      .catch(err => console.error(handle, err));
  });
});
</script>  {% endcomment %}


