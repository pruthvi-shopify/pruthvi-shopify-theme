<form method="post" action="/cart/add" class="gift-card-form">
  <!-- required -->
  <input
    type="hidden"
    name="id"
    value="{{ product.selected_or_first_available_variant.id }}"
  >
  <input
    type="hidden"
    name="__shopify_send_gift_card_to_recipient"
    value="true"
  >

  <h3>Send as a gift</h3>
  <label>Recipient Email *</label>
  <input
    type="email"
    name="Recipient email"
    required
  >

  <label>Recipient Name</label>
  <input
    type="text"
    name="Recipient name"
  >

  <label>Message</label>
  <textarea
    name="Message"
  ></textarea>

  <label>Send on</label>
  <input
    type="date"
    name="Send on"
    min="{{ "now" | date: "%Y-%m-%d" }}"
  >

  <button type="submit" class="btn btn-pink">Add Gift Card</button>
</form>

<style>
  .gift-card-form {
    max-width: 500px;
    margin: 20px 0;
    padding: 25px;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    background-color: #fcfcfc;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  .form-title {
    margin-bottom: 20px;
    font-size: 1.5rem;
    color: #333;
    border-bottom: 2px solid #ff4d8d; /* Pink accent line */
    display: inline-block;
    padding-bottom: 5px;
  }

  /* Grouping labels and inputs */
  .field-group {
    margin-bottom: 15px;
    display: flex;
    flex-direction: column;
  }

  .field-group label {
    margin-bottom: 5px;
    font-weight: 600;
    font-size: 14px;
    color: #444;
  }

  .required {
    color: #ff4d8d;
  }

  /* Input Fields Styling */
  .gift-card-form input[type="email"],
  .gift-card-form input[type="text"],
  .gift-card-form input[type="date"],
  .gift-card-form textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .gift-card-form input:focus,
  .gift-card-form textarea:focus {
    border-color: #ff4d8d;
    box-shadow: 0 0 5px rgba(255, 77, 141, 0.2);
  }

  /* Button Styling */
  .btn-pink {
    width: 100%;
    background-color: #ff4d8d; /* Pink Color */
    color: white;
    padding: 14px;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    text-transform: uppercase;
    transition: background 0.3s ease;
    margin-top: 10px;
  }

  .btn-pink:hover {
    background-color: #e63977;
  }
</style>
