{% comment %} <section class="collection-prod you-may-like">
  <div class="collection-prod-inner">
    <div class="container-fluid">
      <h3 class="text-center">You may also like</h3> {% endcomment %}
      <div class="row">
        {% assign related_products = collections['all-display-products'].products %}
        {% for product in related_products limit: 3 %}
          {% comment %} <div class="col-4 col-s-6">
            <div class="product-card">
              <div class="prod-card-img text-center">
                <div class="prod-card-badge">
                  <div>
                    <form method="post" action="/cart/add" id="product-page-id">
                      <input type="hidden" name="form_type" value="product">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="product-form__submit">
                        <img
                          src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/cart-icon.png?v=1751865122"
                          alt="Add to Cart Icon"
                        >
                      </button>
                    </form>
                  </div>
                  <div>
                     <a href="#" class="quick-view" data-product-handle="{{ product.handle }}">
                            <img width="" height=""
                              src="https://cdn.shopify.com/s/files/1/0640/4839/8454/files/zoom.png?v=1751865146"
                              alt="zoom"
                            >
                          </a>
                  </div>
                </div>
                <div class="prod-img">
                  {% if product.featured_image != blank %}
                    <a href="{{ product.url }}">
                      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
                    </a>
                  {% endif %}
                </div>
                {% if product.variants.size > 1 %}
                  <div class="prod-color mb-1">
                    <ul>
                      {% assign colors = product.variants | map: 'option1' | uniq %}
                      {% for color in colors %}
                        {% assign color_value = color | downcase %}
                        <li>
                          <a
                            href="#"
                            class="card-color-swatch"
                            style="background-color: {{ color_value }};"
                            title="{{ color }}"
                          ></a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                  <!-- UNIQUE SIZES (option2) -->
                  <div class="prod-size-on-hover" style="margin-top: 8px;">
                    <ul style="display: flex; flex-wrap: wrap; gap: 6px; padding: 0; margin: 0; list-style: none;">
                      {% assign unique_sizes = product.variants | map: 'option2' | uniq %}
                      {% for size in unique_sizes %}
                        <li style="display: inline-block;">
                          <span
                            class="card-size-swatch"
                            title="{{ size }}"
                            style="display: inline-block; padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 10px; background: #f8f8f8; color: #333; text-align: center;"
                            onmouseover="this.style.backgroundColor='#222'; this.style.color='#fff'; this.style.borderColor='#222';"
                            onmouseout="this.style.backgroundColor='#f8f8f8'; this.style.color='#333'; this.style.borderColor='#ccc';"
                          >
                            {{ size }}
                          </span>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

              <div class="prod-detail">
                <div class="prod-title">
                  <h4>
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h4>
                </div>
                 <div class="compare-price">
                  {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                    <span
                      ><del>{{ product.selected_or_first_available_variant.compare_at_price | money }}</del></span
                    >
                  {% endif %}
                  <span>{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</span>
                </div> 
              </div>
            </div>
          </div> {% endcomment %}
          {% render 'product-grid', product: product %}
        {% endfor %}
      </div>
    {% comment %} </div>
  </div>
</section> {% endcomment %}




