{% if page.metafields["custom"]["pages1"] != blank %}
  <div class="custom-field custom-field__pages1 custom-field__type--date-time">
    <h3 class="custom-field--title">pages1</h3>
    <div class="custom-field--value">
      {{ page.metafields["custom"]["pages1"] | date: "%m/%d/%Y %I:%M:%S %p" }}
    </div>
  </div>
{% endif %}