{% if product.metafields["custom"]["demo"] != blank %}
  <div class="custom-field custom-field__demo custom-field__type--date-time">
    <h3 class="custom-field--title">Demo</h3>
    <div class="custom-field--value">
      {{ product.metafields["custom"]["demo"] | date: "%m/%d/%Y %I:%M:%S %p" }}
    </div>
  </div>
{% endif %}