<section class="user-section">
  <div class="container">
    <div class="account-section">
      <div class="account-navigation">
        <ul>
          <li><a href="/account">My Account</a></li>
          <li class="active"><a href="/account/addresses">My Addresses</a></li>
          <li><a href="/account?view=order_history">Order History</a></li>
          {% if customer %}
            <li>{{ 'layout.customer.log_out' | t | customer_logout_link }}</li>
          {% endif %}
        </ul>
      </div>

      <div class="account-content">
        <div class="account-cover">
          <div class="row">
            <!-- <h2>{{ 'customer.addresses.title' | t }}</h2> -->
            {% for address in customer.addresses %}
              <div class="col-two account-wrap">
                <div class="address-cover">
                  <h2 class="account-title mb-3">
                    {{ address.first_name | capitalize }}
                    {{ address.last_name | capitalize }}
                    {% if address == customer.default_address %}({{ 'customer.addresses.default' | t }}){% endif %}
                  </h2>

                  <p>
                    {{ address.company -}}
                    <br>
                    {{ address.street -}}
                    <br>
                    {{ address.city | capitalize -}}
                    <br>
                    {% if address.province_code %}
                      {{ address.province_code | upcase -}}
                      <br>
                    {% endif %}
                    {{ address.zip | upcase -}}
                    <br>
                    {{ address.country -}}
                    <br>
                    {{ address.phone }}
                  </p>
                  <div class="btn-box">
                    <div
                      class="button edit-{{ forloop.index }} editbuttonClass"
                      data-id="change-address-{{forloop.index}}"
                    >
                      <!--
                        {{ 'customer.addresses.edit' | t | edit_customer_address_link: address.id | replace: '<a', '<a class="btn edit changeaddress"' }}
                      -->
                      <a href="#" class="btn edit changeaddress">Edit</a>     
                    </div>
                    <div class="button">
                      {{
                        'customer.addresses.delete'
                        | t
                        | delete_customer_address_link: address.id
                        | replace: '<a', '<a class="btn delete"'
                      }}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          <!-- <h1 class="section-header__title section-header__title--left">{{ 'customer.account.title' | t }}</h1> -->

          <div class="edit-address editbuttonClass" data-id="openNewForm">
            <a href="#" class="btn changeaddress">{{ 'customer.addresses.add_new' | t }}</a>
          </div>

          <!-- <p><a href="/account">{{ 'customer.account.return' | t }}</a></p> -->

          {% comment %}
            Add address form, hidden by default
          {% endcomment %}
          <div class="edit-address-box editformClass openNewForm" id="AddressOne">
            <div class="form-block">
              <h2 class="account-title">{{ 'customer.addresses.add_new' | t }}</h2>
              <div class="address-form form-wrap">
                {% form 'customer_address', customer.new_address %}
                  <div id="AddAddress" class="row">
                    {{ form.errors | default_errors }}

                    <div class="col-two form-group">
                      <label for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
                      <input
                        type="text"
                        id="AddressFirstNameNew"
                        class="form-control"
                        name="address[first_name]"
                        value="{{form.first_name}}"
                        autocapitalize="words"
                        aria-describedby="textHelp"
                      >
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
                      <input
                        type="text"
                        id="AddressLastNameNew"
                        class="form-control"
                        name="address[last_name]"
                        value="{{form.last_name}}"
                        autocapitalize="words"
                        aria-describedby="textHelp"
                      >
                    </div>
                    <div class="col-full form-group">
                      <label for="AddressCompanyNew">{{ 'customer.addresses.company' | t }}</label>
                      <input
                        type="text"
                        id="AddressCompanyNew"
                        class="form-control"
                        name="address[company]"
                        value="{{form.company}}"
                        autocapitalize="words"
                      >
                    </div>
                    <div class="col-full form-group">
                      <label for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
                      <input
                        type="text"
                        id="AddressAddress1New"
                        class="form-control"
                        name="address[address1]"
                        value="{{form.address1}}"
                        autocapitalize="words"
                      >
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
                      <input
                        type="text"
                        id="AddressAddress2New"
                        class="form-control"
                        name="address[address2]"
                        value="{{form.address2}}"
                        autocapitalize="words"
                      >
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
                      <select
                        class="form-control"
                        id="AddressCountryNew"
                        name="address[country]"
                        data-default="{{form.country}}"
                      >
                        {{ country_option_tags }}
                      </select>
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
                      <input
                        type="text"
                        id="AddressCityNew"
                        class="form-control"
                        name="address[city]"
                        value="{{form.city}}"
                        autocapitalize="words"
                      >
                    </div>
                    <div class="col-two form-group" id="AddressProvinceContainerNew" style="display:none">
                      <label for="AddressProvinceNew">{{ 'customer.addresses.province' | t }}</label>
                      <select
                        id="AddressProvinceNew"
                        class="form-control"
                        name="address[province]"
                        data-default="{{form.province}}"
                      ></select>
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
                      <input
                        type="text"
                        id="AddressZipNew"
                        class="form-control"
                        name="address[zip]"
                        value="{{form.zip}}"
                        autocapitalize="characters"
                      >
                    </div>
                    <div class="col-two form-group">
                      <label for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
                      <input
                        type="tel"
                        id="AddressPhoneNew"
                        class="form-control"
                        name="address[phone]"
                        value="{{form.phone}}"
                      >
                    </div>
                  </div>
                  <label for="address_default_address_new" class="inline">
                    {{- form.set_as_default_checkbox -}}
                    {{- 'customer.addresses.set_default' | t -}}
                  </label>
                  <div class="pt-20 button text-center">
                    <button type="submit" class="btn" value="{{ 'customer.addresses.add' | t }}">
                      {{ 'customer.addresses.add' | t }}
                    </button>
                    <a class="btn" href="#" onclick="Shopify.CustomerAddress.toggleNewForm();">
                      {{- 'customer.addresses.cancel' | t -}}
                    </a>
                  </div>

                  <!-- <p><input type="submit" class="btn" value="{{ 'customer.addresses.add' | t }}"></p> -->
                {% endform %}
              </div>
            </div>
          </div>

         

          {% for address in customer.addresses %}
            <div class="change-address-{{ forloop.index }} bgcolor4 editformClass">
              <div class="form-block">
                <div class="address-form form-wrap">
                  {% form 'customer_address', address %}
                    <div
                      id="EditAddress_{{address.id}}"
                      class="edit_add"
                      style="padding:20px 30px 30px;{% unless form.errors %}display:none;{% endunless %}"
                    >
                      <h2 class="account-title">{{ 'customer.addresses.edit_address' | t }}</h2>
                      <div class="row">
                        {{ form.errors | default_errors }}
                        <div class="col-two form-group">
                          <label for="AddressFirstName_{{form.id}}">{{ 'customer.addresses.first_name' | t }}</label>
                          <input
                            type="text"
                            id="AddressFirstName_{{form.id}}"
                            class="form-control"
                            name="address[first_name]"
                            value="{{form.first_name}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressLastName_{{form.id}}">{{ 'customer.addresses.last_name' | t }}</label>
                          <input
                            type="text"
                            id="AddressLastName_{{form.id}}"
                            class="form-control"
                            name="address[last_name]"
                            value="{{form.last_name}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-full form-group">
                          <label for="AddressCompany_{{form.id}}">{{ 'customer.addresses.company' | t }}</label>
                          <input
                            type="text"
                            id="AddressCompany_{{form.id}}"
                            class="form-control"
                            name="address[company]"
                            value="{{form.company}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-full form-group">
                          <label for="AddressAddress1_{{form.id}}">{{ 'customer.addresses.address1' | t }}</label>
                          <input
                            type="text"
                            id="AddressAddress1_{{form.id}}"
                            class="form-control"
                            name="address[address1]"
                            value="{{form.address1}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressAddress2_{{form.id}}">{{ 'customer.addresses.address2' | t }}</label>
                          <input
                            type="text"
                            id="AddressAddress2_{{form.id}}"
                            class="form-control"
                            name="address[address2]"
                            value="{{form.address2}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressCountry_{{form.id}}">{{ 'customer.addresses.country' | t }}</label>
                          <select
                            class="form-control"
                            id="AddressCountry_{{form.id}}"
                            name="address[country]"
                            data-default="{{form.country}}"
                          >  
                            {{ country_option_tags }}
                          </select>
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressCity_{{form.id}}">{{ 'customer.addresses.city' | t }}</label>
                          <input
                            type="text"
                            id="AddressCity_{{form.id}}"
                            class="address_form"
                            name="address[city]"
                            value="{{form.city}}"
                            autocapitalize="words"
                          >
                        </div>
                        <div class="col-two form-group">
                          <div id="AddressProvinceContainer_{{form.id}}" style="display:none">
                            <label for="AddressProvince_{{form.id}}">{{ 'customer.addresses.province' | t }}</label>
                            <select
                              id="AddressProvince_{{form.id}}"
                              class="address_form"
                              name="address[province]"
                              data-default="{{form.province}}"
                            ></select>
                          </div>
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressZip_{{form.id}}">{{ 'customer.addresses.zip' | t }}</label>
                          <input
                            type="text"
                            id="AddressZip_{{form.id}}"
                            class="address_form"
                            name="address[zip]"
                            value="{{form.zip}}"
                            autocapitalize="characters"
                          >
                        </div>
                        <div class="col-two form-group">
                          <label for="AddressPhone_{{form.id}}">{{ 'customer.addresses.phone' | t }}</label>
                          <input
                            type="tel"
                            id="AddressPhone_{{form.id}}"
                            class="address_form"
                            name="address[phone]"
                            value="{{form.phone}}"
                          >
                        </div>
                      </div>
                      <label for="address_default_address_{{form.id}}" class="inline">
                        {{- form.set_as_default_checkbox -}}
                        {{- 'customer.addresses.set_default' | t -}}
                      </label>
                      <div class="pt-20 button text-center">
                        <button type="submit" class="btn" value="{{ 'customer.addresses.update' | t }}">
                          {{ 'customer.addresses.update' | t }}
                        </button>
                        <a
                          href="#"           
                          class="btn cancel_form"
                          onclick="Shopify.CustomerAddress.toggleForm({{form.id}}); return false;"
                        >
                          {{- 'customer.addresses.cancel' | t -}}
                        </a>
                      </div>
                    </div>
                  {% endform %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  // Initialize observers on address selectors
  new Shopify.CountryProvinceSelector('AddressCountryNew', 'AddressProvinceNew', {
    hideElement: 'AddressProvinceContainerNew'
  });

  // Setup province selector on each customer address
  {% for address in customer.addresses %}
  new Shopify.CountryProvinceSelector('AddressCountry_{{address.id}}', 'AddressProvince_{{address.id}}', {
                                      hideElement: 'AddressProvinceContainer_{{address.id}}'}
                                     );
  {% endfor %}


  Shopify.CustomerAddress = {

toggleForm: function(id) {
      var editEl = document.getElementById('EditAddress_'+id);
      console.log(editEl);
      editEl.style.display = editEl.style.display == 'none' ? '' : 'none';
      return false;
    },

    toggleNewForm: function() {
      var el = document.getElementById('AddressOne');
      console.log(el);
      el.style.display = el.style.display == 'none' ? '' : 'none';
      return false;
    },

    destroy: function(id, confirm_msg) {
      if (confirm(confirm_msg || "Are you sure you wish to delete this address?")) {
        Shopify.postLink('/account/addresses/'+id, {'parameters': {'_method': 'delete'}});
      }
    }
  }

   {% comment %} $('.changeaddress').click(function (e) {
    e.preventDefault();
    if($(this).hasClass('active')) {
      $('.editformClass').slideUp();
      $('.changeaddress').removeClass('active');
    } else {
      $('.changeaddress').removeClass('active');
      $(this).addClass('active');
      var x = $(this).closest('.editbuttonClass').data('id');
      $('.editformClass.'+x).slideDown();

      $('.editformClass').slideUp();
      $('.editformClass.'+x).slideDown(function(){
        $('html, body').animate({
          scrollTop: $("."+x).offset().top
        }, 1000);
      });
    }
  })
  $('.cancel_form').click(function(){
    $('.editformClass').fadeOut('slow');
  }); {% endcomment %}

$('.changeaddress').click(function (e) {
  e.preventDefault();

  let targetClass = $(this).closest('.editbuttonClass').data('id');
  let targetForm = $('.editformClass.' + targetClass);

  // Close all
  $('.editformClass').slideUp();
  $('.changeaddress').removeClass('active');

  // NEW: Detect if clicked is "Add New Address" button
  if (targetClass === "openNewForm") {
      $('#AddressOne').slideDown();   // open new address form
      $(this).addClass('active');

      $('html, body').animate({
        scrollTop: $('#AddressOne').offset().top
      }, 700);
      return;
  }

  // Open Edit Form
  $(this).addClass('active');
  targetForm.slideDown(function () {
    $('html, body').animate({
      scrollTop: targetForm.offset().top
    }, 700);
  });
});


// CANCEL — close everything
$('.cancel_form').click(function (e) {
  e.preventDefault();
  $('.editformClass').slideUp();
  $('.changeaddress').removeClass('active');
});

</script>


<style>
  .edit_add {
    display: block !important;
  }
  
  .editformClass.openNewForm {
  display: block; /* allow new form to show */
}
</style>

